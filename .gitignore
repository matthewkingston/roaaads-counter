# Precomputed paths cache (large binary, regenerated by build_paths.py)
simulation/newtownards_paths.npz

# Generated pipeline outputs (all regenerated by running build_*.py scripts)
simulation/*.html
simulation/*.graphml
simulation/*.geojson
simulation/*.json
simulation/*.osm
simulation/*.osm.pbf
simulation/*.o5m
!simulation/tuner_config.json
simulation/dz2021/DZ2021.geojson

# Downloaded/cached data (regenerated automatically on first run)
data/cache_*
cache/

# Large reference data files — kept locally but not committed
data/*.ods
data/*.xlsx

# Generated reports (produced by report_tune.py and tune_assignment.py)
reports/

# Python bytecode
__pycache__/
*.pyc
